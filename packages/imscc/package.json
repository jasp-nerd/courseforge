{
  "name": "@courseforge/imscc",
  "version": "0.2.1",
  "description": "Build, parse, modify, and validate Canvas-flavored IMS Common Cartridge (.imscc) course files — works in Node and the browser",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "courseforge-imscc": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@courseforge/shared": "workspace:*",
    "fast-xml-parser": "^5.3.2",
    "fflate": "^0.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasp-nerd/courseforge.git",
    "directory": "packages/imscc"
  },
  "keywords": [
    "imscc",
    "common-cartridge",
    "canvas-lms",
    "canvas",
    "lms",
    "course",
    "qti",
    "edtech",
    "1edtech",
    "ims"
  ]
}
